#!/bin/sh
# Wrapper script for fuzzel's launch-prefix.
# Extracts the app name from the command and notifies hyprloading before exec.
#
# Usage: Set in fuzzel.ini:
#   launch-prefix=/path/to/hyprloading-launch

# Get the binary name from the first argument
APP=$(basename "$1" 2>/dev/null)

# Strip common suffixes
APP="${APP%.desktop}"

if [ -n "$APP" ]; then
    hyprctl dispatch hyprloading:launch "$APP" &
fi

exec "$@"
